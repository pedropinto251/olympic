<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="649.0" prefWidth="1092.0" style="-fx-background-color: #18191A;" stylesheets="@../stylesheet.css" xmlns="http://javafx.com/javafx/20.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lp3_grupo5.lp3_grupo5.Controller.Sports.SportFXMLController">
    <children>
        <!-- Botão para escolher XML -->
        <Label layoutX="338.0" layoutY="30.0" text="Escolha o arquivo XML:" textFill="#FFFFFF">
         <font>
            <Font size="16.0" />
         </font></Label>
        <Button layoutX="523.0" layoutY="18.0" onAction="#handleSelectXML" prefHeight="26.0" prefWidth="236.0" style="-fx-background-color: none; -fx-border-color: white;" text="Selecionar XML" textFill="WHITE" fx:id="xmlButton">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
            <style>
                .button:hover {
                -fx-background-color: #4A4B4C;
                -fx-cursor: hand;
                }
            </style>
        </Button>

        <!-- Botão para escolher XSD -->
        <Label layoutX="339.0" layoutY="86.0" text="Escolha o arquivo XSD:" textFill="#FFFFFF">
         <font>
            <Font size="16.0" />
         </font></Label>
        <Button layoutX="523.0" layoutY="74.0" onAction="#handleSelectXSD" prefHeight="26.0" prefWidth="236.0" style="-fx-background-color: none; -fx-border-color: white;" text="Selecionar XSD" textFill="WHITE" fx:id="xsdButton">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
            <style>
                .button:hover {
                -fx-background-color: #4A4B4C;
                -fx-cursor: hand;
                }
            </style>
        </Button>

        <!-- Área de status para mensagens -->
        <TextArea fx:id="statusArea" editable="false" layoutX="17.0" layoutY="445.0" prefHeight="100" prefWidth="1054.0" style="-fx-background-color: none; -fx-border-color: white; -fx-text-fill: WHITE;" wrapText="true" />
        <Button fx:id="carregarButton" layoutX="17.0" layoutY="391.0" onAction="#handleCarregarDesportos" prefHeight="41.0" prefWidth="257.0" style="-fx-background-color: none; -fx-border-color: white;" text="Carregar Desportos" textFill="WHITE">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
            <style>
                .button:hover {
                -fx-background-color: #4A4B4C;
                -fx-cursor: hand;
                }
            </style>
        </Button>
        <TableView fx:id="sportTableView" layoutX="17.0" layoutY="132.0" prefHeight="246.0" prefWidth="1054.0" styleClass="table-view">
            <columns>
                <TableColumn fx:id="typeColumn" prefWidth="52.0" text="Tipo" />
                <TableColumn fx:id="genreColumn" prefWidth="67.0" text="Gênero" />
                <TableColumn fx:id="nameColumn" prefWidth="158.0" text="Nome" />
                <TableColumn fx:id="descriptionColumn" prefWidth="87.0" text="Descrição" />
                <TableColumn fx:id="minParticipantsColumn" prefWidth="156.0" text="Participantes Mínimos" />
                <TableColumn fx:id="scoringMeasureColumn" prefWidth="149.0" text="Medida de Pontuação" />
                <TableColumn fx:id="oneGameColumn" prefWidth="79.0" text="Um Jogo" />
                <TableColumn fx:id="olympicRecordColumn" prefWidth="131.0" text="Recorde Olímpico" />
                <TableColumn fx:id="winnerOlympicColumn" prefWidth="152.0" text="Vencedor Olímpico" />
            </columns>
        </TableView>
        <Button fx:id="menuBtn" layoutX="906.0" layoutY="563.0" onAction="#handleVoltarMenu" prefHeight="53.0" prefWidth="165.0" style="-fx-background-color: none; -fx-border-color: white;" text="Menu" textFill="WHITE">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
            <style>
                .button:hover {
                -fx-background-color: #4A4B4C;
                -fx-cursor: hand;
                }
            </style>
        </Button>
        <Button fx:id="btnBack" layoutX="17.0" layoutY="563.0" onAction="#handleBtnBack" prefHeight="53.0" prefWidth="165.0" style="-fx-background-color: none; -fx-border-color: white;" text="Retroceder" textFill="WHITE">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
            <style>
                .button:hover {
                -fx-background-color: #4A4B4C;
                -fx-cursor: hand;
                }
            </style>
        </Button>
    </children>
</AnchorPane>
