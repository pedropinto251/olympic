@model LP_API.Model.LoginModel

<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <style>
        body {
            background-color: #007bff; /* Fundo azul */
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            background: url('/images/Background.png') no-repeat center center;
            background-size: cover;
        }

        .form-container {
            background-color: rgba(255, 255, 255, 0.9);
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            text-align: center;
            max-width: 400px;
        }

        h2 {
            color: #007bff;
            margin-bottom: 20px;
            font-size: 2.5rem;
            font-weight: bold;
        }

        .form-group label {
            color: #007bff;
            font-weight: bold;
        }

        .form-group input {
            margin-bottom: 20px;
        }

        .btn-primary {
            background-color: #007bff;
            border-color: #007bff;
            font-size: 1.2rem;
            padding: 10px 20px;
            border-radius: 5px;
        }

            .btn-primary:hover {
                background-color: #0056b3;
                border-color: #0056b3;
            }

        .btn-secondary {
            background-color: #0056b3;
            border-color: #0056b3;
            font-size: 1.2rem;
            padding: 10px 20px;
            border-radius: 5px;
            color: white;
        }

            .btn-secondary:hover {
                background-color: #003f7f;
                border-color: #003f7f;
            }

        .text-center a {
            color: #007bff;
            font-weight: bold;
        }

        .invalid-field {
            border-color: red;
        }
    </style>
</head>
<body>
    <div class="form-container">
        <h2 class="text-center">Login</h2>
        <form asp-action="Index" method="post" id="loginForm">
            <div class="form-group">
                <label for="Email">Email</label>
                <input id="Email" name="Email" class="form-control" value="@Model.Email" placeholder="Introduza o seu email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label for="Password">Palavra-passe</label>
                <input id="Password" name="Password" type="password" class="form-control" value="@Model.Password" placeholder="Introduza a sua palavra-passe" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div id="error-message" class="text-danger" style="display:none;">Email ou palavra-passe incorretos.</div>
            <button type="submit" class="btn btn-primary btn-block">Login</button>
        </form>
        <div class="text-center mt-3">
            <a href="https://localhost:7268/Client/Register" class="btn btn-secondary">Registar</a>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.2/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.11/dist/jquery.validate.unobtrusive.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#loginForm').on('submit', function (e) {
                e.preventDefault(); // Impede o envio padrão do formulário

                var form = $(this);
                var url = form.attr('action');
                var formData = form.serialize();

                $.post(url, formData)
                    .done(function (response) {
                        // Sucesso - redirecionar para a página de sucesso
                        window.location.href = "/Login/success";
                    })
                    .fail(function (xhr) {
                        if (xhr.status === 406) {
                            $('#error-message').show();
                        } else {
                            // Tratar outros erros
                        }
                    });
            });
        });
    </script>
</body>
</html>