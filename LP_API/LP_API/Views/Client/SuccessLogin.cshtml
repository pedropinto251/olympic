@model LP_API.Model.SessionModel

<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Successful</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <style>
        body {
            background-color: #f8f9fa;
            padding-top: 56px;
        }

        .navbar {
            background-color: #007bff;
        }

        .navbar-brand, .nav-link, .navbar-text {
            color: white !important;
        }

        .footer {
            background-color: #007bff;
            color: white;
            padding: 10px 0;
            position: fixed;
            bottom: 0;
            width: 100%;
            text-align: center;
        }

        .card {
            margin-top: 20px;
            border: none;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .card-body {
            padding: 30px;
        }

        .btn-primary {
            background-color: #007bff;
            border-color: #007bff;
        }

            .btn-primary:hover {
                background-color: #0056b3;
                border-color: #0056b3;
            }

        h2 {
            margin-bottom: 20px;
            color: #333;
        }

        h5 {
            color: #007bff;
        }

        p {
            font-size: 16px;
            color: #555;
        }

        .settings-icon {
            font-size: 1.5rem;
            color: white;
        }

        .quote {
            font-size: 1.5rem;
            font-weight: bold;
            color: #007bff;
            background-color: #e9ecef;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            margin-top: 40px;
        }

        .hero {
            background: url('/images/Background.png') no-repeat center center;
            background-size: cover;
            color: white;
            padding: 100px 0;
            text-align: center;
        }

            .hero h1 {
                font-size: 3rem;
                font-weight: bold;
                color: #333; /* Mudança de cor para melhor visibilidade */
            }

            .hero p {
                font-size: 1.5rem;
                color: #333; /* Mudança de cor para melhor visibilidade */
            }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary fixed-top">
        <a class="navbar-brand" href="#">Oporto Olympics</a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav mr-auto">
                <li class="nav-item active">
                    <a class="nav-link" href="#">Home <span class="sr-only">(página atual)</span></a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Game">Ver Jogos</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Ticket/Index">Bilhetes</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/ChangePassword">Change Password</a>
                </li>
            </ul>
            <ul class="navbar-nav ml-auto">
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle settings-icon" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                        <i class="fas fa-cog"></i> Settings
                    </a>
                    <div class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
                        <a class="dropdown-item" href="/Account/DeleteAccount">Apagar Conta</a>
                    </div>
                </li>
            </ul>
        </div>
    </nav>

    <div class="hero">
        <h1>Bem-vindo ao Oporto Olympics</h1>
        <p>Onde o desporto encontra a excelência</p>
    </div>

    <div class="container mt-5">
        <h2>Login Successful</h2>
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Detalhes do Cliente</h5>
                <p class="card-text"><strong>Id:</strong> @Model.Id</p>
                <p class="card-text"><strong>GroupId:</strong> @Model.GroupId</p>
                <p class="card-text"><strong>Name:</strong> @Model.Name</p>
                <p class="card-text"><strong>Email:</strong> @Model.Email</p>
                <p class="card-text"><strong>Active:</strong> @Model.Active</p>
            </div>
        </div>
        <div class="quote text-center">
            <p class="lead">"O desporto é a superação dos nossos próprios limites."</p>
        </div>
    </div>

    <footer class="footer">
        <div class="container">
            <span class="text-muted">© 2025 Oporto Olympics. Todos os direitos reservados.</span>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://kit.fontawesome.com/a076d05399.js"></script> <!-- Adiciona FontAwesome para o ícone de engrenagem -->
</body>
</html>